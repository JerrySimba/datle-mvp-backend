NODE_ENV=production
PORT=4000
DATABASE_URL="postgresql://user:password@host:5432/datle_mvp?schema=public"
JWT_SECRET="replace_with_a_long_random_secret"
CORS_ORIGIN="https://your-dashboard-domain.com,https://your-respondent-domain.com"
OTP_EMAIL_PROVIDER="resend"
OTP_SMS_PROVIDER="twilio"
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="DatLe <noreply@yourdomain.com>"
RESEND_REPLY_TO="support@yourdomain.com"
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_FROM_NUMBER="+1xxxxxxxxxx"
TWILIO_MESSAGING_SERVICE_SID=""
OTP_EMAIL_SUBJECT="Your DatLe verification code"
OPENAI_API_KEY="sk-proj-..."
OPENAI_MODEL="gpt-5.2"
OTP_TTL_MINUTES=10
AUTH_TOKEN_TTL_MINUTES=1440
AUTH_MAX_ATTEMPTS=5
AUTH_LOCK_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# Frontend production env files:
# dashboard/.env.production -> VITE_API_BASE_URL=https://your-api-domain.com
# respondent-app/.env.production -> VITE_API_BASE_URL=https://your-api-domain.com
